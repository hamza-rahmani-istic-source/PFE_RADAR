[Unit]
Description=AI Camera Final Pipeline (Raspberry)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ai_camera
ExecStart=/home/pi/ai_camera/venv/bin/python -u /home/pi/ai_camera/final_pi.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
